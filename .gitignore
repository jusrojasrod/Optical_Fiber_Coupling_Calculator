# ==========================================
# Entornos virtuales y variables de entorno
# ==========================================
.venv/
venv/
env/
.env

# ==========================================
# Archivos compilados y caché de Python
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# Jupyter Notebooks y Herramientas
# ==========================================
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ==========================================
# Datos y Resultados
# ==========================================
# Ignorar el contenido de datos pero mantener estructura
data/01_raw/*
data/02_interim/*
data/03_processed/*
!data/**/.gitkeep

# Evitar subir gráficas o exportaciones de alta resolución por accidente
*.png
*.pdf
*.svg
*.eps

